# Copy to frontend/.env.production (or set in the shell) BEFORE `npm run build`.
# NEXT_PUBLIC_* variables are inlined into the client bundle at build time.
#
# Leave as the same-origin default when serving behind the provided nginx
# config (nginx proxies /api/ to the backend). Only override if the backend
# lives on a different host/origin.
NEXT_PUBLIC_API_URL=/api/v1
